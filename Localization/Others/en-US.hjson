				SHPBowHoldout.DisplayName: S.H.P.B. Holdout
				SHPBowSelectionPanel.DisplayName: SHP Core Wheel
				SHPBowArrow.DisplayName: SHP Core Arrow
			}
		}

		Keybinds: {
			LegendarySkill: Legendary skill
			Mods.CalamityLegendsComeBack.Keybinds.LegendarySkill.DisplayName: Mods. Calamity Legends Come Back. Keybinds. Legendary Skill
		}
	}
